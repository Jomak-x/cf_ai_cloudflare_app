{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],
		"allowJs": false,
		"baseUrl": ".",
		"paths": {
			"@/*": ["app/src/*"]
		}
	},
	"include": ["app/src/**/*.ts", "app/src/**/*.tsx", "vite.config.ts"],
	"exclude": ["src", "test", "dist"]
}
